{
  "name": "skillmux",
  "version": "0.1.2",
  "description": "CLI for managing local agent skills from a shared SkillMux store",
  "type": "module",
  "bin": {
    "skillmux": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
